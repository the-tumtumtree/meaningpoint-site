---
const phrase = 'We write. It works. ';
---

<div class="marquee-wrap" aria-hidden="true">
  <div class="marquee-track">
    <span class="marquee-segment">{phrase.repeat(16)}</span>
    <span class="marquee-segment" aria-hidden="true">{phrase.repeat(16)}</span>
  </div>
</div>

<script is:inline>
  (function () {
    var PHRASE = 'We write. It works. ';
    var track = document.querySelector('.marquee-track');
    if (!track) return;

    var pos = 0;
    var lastScrollY = window.scrollY;
    var loopWidth = 0;

    function segments() {
      return track.querySelectorAll('.marquee-segment');
    }

    function ensureSegmentWidth() {
      var items = segments();
      var first = items[0];
      var second = items[1];
      if (!first || !second) return;

      var minWidth = window.innerWidth * 2;
      while (first.scrollWidth < minWidth) {
        first.textContent += PHRASE;
      }
      second.textContent = first.textContent;
    }

    function measure() {
      ensureSegmentWidth();
      var first = segments()[0];
      loopWidth = first ? first.scrollWidth : track.scrollWidth / 2;
    }

    function update() {
      if (loopWidth <= 0) return;
      var wrapped = ((pos % loopWidth) + loopWidth) % loopWidth;
      track.style.transform = 'translateX(' + (wrapped - loopWidth) + 'px)';
    }

    measure();
    update();

    window.addEventListener(
      'resize',
      function () {
        measure();
        update();
      }
    );

    window.addEventListener(
      'scroll',
      function () {
        var delta = window.scrollY - lastScrollY;
        lastScrollY = window.scrollY;
        pos += delta * 0.85;
        update();
      }
    );
  })();
</script>
