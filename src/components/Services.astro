---
import { getCollection } from 'astro:content';

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="services" class="services">
  <div class="container">
    <div class="services-layout">
      <div class="services-panels">
        {
          services.map((s, i) => (
            <article
              id={`service-panel-${s.id}`}
              class:list={['service-card', 'service-panel', { 'is-active': i === 0 }]}
              style={`background: ${s.data.color}; color: ${s.data.textColor ?? '#444'}`}
              role="tabpanel"
              aria-labelledby={`service-tab-${s.id}`}
              data-service-panel={s.id}
            >
              <h3>{s.data.title}</h3>
              {s.data.description?.map((p) => <p>{p}</p>)}
              {s.data.details && (
                <div class="service-card__details">
                  {s.data.details.map((detail) => <p>{detail}</p>)}
                </div>
              )}
              {s.data.metrics && (
                <div class="service-card__metrics">
                  <p>{s.data.metrics.join(' · ')}</p>
                </div>
              )}
              <p class="service-card__label">what you get</p>
              {(s.data.whatYouGet ?? s.data.description ?? []).length > 1 ? (
                <ul class="service-card__list">
                  {(s.data.whatYouGet ?? s.data.description ?? []).map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              ) : (
                (s.data.whatYouGet ?? s.data.description ?? []).map((p) => <p>{p}</p>)
              )}
            </article>
          ))
        }
      </div>

      <div class="services-tabs" role="tablist" aria-label="Services">
        {
          services.map((s, i) => (
            <button
              type="button"
              class="services-tab"
              role="tab"
              id={`service-tab-${s.id}`}
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`service-panel-${s.id}`}
              data-service-tab={s.id}
              style={`--tab-color: ${s.data.color}; --tab-text: ${s.data.textColor ?? '#444444'}`}
            >
              {s.data.title}
            </button>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var root = document.querySelector('.services');
    var tabs = document.querySelectorAll('[data-service-tab]');
    var panels = document.querySelectorAll('[data-service-panel]');
    if (root) root.classList.add('is-enhanced');

    Array.prototype.forEach.call(tabs, function (tab) {
      tab.addEventListener('click', function () {
        var id = tab.getAttribute('data-service-tab');
        Array.prototype.forEach.call(tabs, function (t) {
          t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
        });
        Array.prototype.forEach.call(panels, function (p) {
          p.classList.toggle('is-active', p.getAttribute('data-service-panel') === id);
        });
      });
    });
  })();
</script>
