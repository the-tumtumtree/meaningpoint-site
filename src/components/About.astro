---
import startups from '../content/audiences/01-startups.json';
import companies from '../content/audiences/02-companies.json';
import agencies from '../content/audiences/03-agencies.json';
import personal from '../content/audiences/04-personal.json';

const audiences = [startups, companies, agencies, personal].sort(
  (a, b) => a.order - b.order
);
---

<section id="about" class="about">
  <div class="container">
    <h2 class="operate__title">We create brand languages people love and copy that hits the mark</h2>
    <ul class="about__columns operate__steps">
      {
        audiences.map((a) => (
          <li class="about__column">
            <span class="about__emoji" aria-hidden="true">{a.emoji}</span>
            <span class="about__text">
              <strong>{a.label}</strong> {a.description}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
  <div class="about-startups-marquee" data-about-startups-marquee>
    <div class="about-startups-marquee__track" data-about-startups-marquee-track>
      <a
        class="about-startups-marquee__link"
        href="/startups"
        target="_blank"
        rel="noopener noreferrer"
      >
        <strong>Check out our special offer for startups</strong>
        <span class="about-startups-marquee__rocket" aria-hidden="true">🚀</span>
      </a>
    </div>
  </div>
</section>

<style is:global>
  .about {
    position: relative;
    z-index: 2;
    --about-marquee-gap: clamp(2.5rem, 6vw, 4rem);
    padding: var(--section-pad) 0 var(--about-marquee-gap);
    font-family: var(--font-display);
    color: var(--color-cream);
  }

  .about .operate__title {
    margin-bottom: 2.5rem;
  }

  .about__columns {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .about__column {
    display: block;
    min-width: 0;
  }

  .about__emoji {
    display: block;
    margin-bottom: 0.35rem;
    font-size: var(--fs-xl);
    line-height: 1;
  }

  .about__text {
    display: block;
  }

  .about__column strong {
    font-weight: 700;
  }

  .about-startups-marquee {
    width: 100%;
    margin-top: var(--about-marquee-gap);
    overflow: hidden;
    color: #ff7a7a;
  }

  .about-startups-marquee__track {
    display: flex;
    width: 100%;
    will-change: transform;
  }

  .about-startups-marquee__link {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: inherit;
    font-size: 1rem;
    font-weight: 700 !important;
    line-height: 1.35;
    white-space: nowrap;
  }

  .about-startups-marquee__link strong {
    font-weight: 700 !important;
  }

  .about-startups-marquee__rocket {
    display: inline-block;
    transform: rotate(45deg) !important;
    -webkit-transform: rotate(45deg) !important;
    transform-origin: center;
  }

  @media (max-width: 900px) {
    .about__columns {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 520px) {
    .about__columns {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  (function () {
    var root = document.querySelector('[data-about-startups-marquee]');
    var track = document.querySelector('[data-about-startups-marquee-track]');
    if (!root || !track) return;

    function update() {
      var link = track.querySelector('.about-startups-marquee__link');
      if (!link) return;
      var isSmallScreen = window.matchMedia('(max-width: 520px)').matches;
      var maxShift = isSmallScreen
        ? root.clientWidth
        : Math.max(root.clientWidth - link.offsetWidth, 0);
      var rect = root.getBoundingClientRect();
      var travel = window.innerHeight + root.offsetHeight;
      var progress = (window.innerHeight - rect.top) / travel;
      var speed = isSmallScreen ? 2.1 : 1;
      progress *= speed;
      progress = Math.max(0, Math.min(progress, 1));
      track.style.transform = 'translateX(' + maxShift * progress + 'px)';
    }

    update();

    window.addEventListener('resize', function () {
      update();
    });

    window.addEventListener('scroll', update, { passive: true });
  })();
</script>
