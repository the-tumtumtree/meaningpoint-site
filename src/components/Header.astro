---
interface Props {
  logoHref?: string;
  navBase?: string;
}

const { logoHref = '#top', navBase = '' } = Astro.props;
const casesHref = `${navBase}#cases`;
const servicesHref = `${navBase}#services`;
const teamHref = `${navBase}#team`;
---

<header class="site-header">
  <div class="container">
    <a href={logoHref} class="logo">Meaning Point</a>
    <nav class="nav-main" aria-label="Main">
      <div class="nav-pill">
        <a href={casesHref}>Cases</a>
        <a href={servicesHref}>Services</a>
        <a href={teamHref}>Team</a>
      </div>
      <div class="nav-contacts" aria-label="Contact">
        <a href="mailto:hi@meaningpoint.one" title="Email">💌</a>
        <a
          href="https://calendly.com/alexandra_mp/30min?month=2026-06"
          target="_blank"
          rel="noopener noreferrer"
          title="Book a call">📅</a
        >
        <a
          href="https://www.linkedin.com/company/meaningpoint/"
          target="_blank"
          rel="noopener noreferrer"
          title="LinkedIn">🔗</a
        >
      </div>
    </nav>
    <nav class="nav-mobile" aria-label="Main mobile">
      <a href={casesHref}>Cases</a>
      <a href={servicesHref}>Services</a>
      <a href={teamHref}>Team</a>
    </nav>
  </div>
</header>
